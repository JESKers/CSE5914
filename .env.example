# Copy to .env and fill in. docker-compose reads this file.

# Elasticsearch. Leave as localhost — this is what host-side tools (pytest,
# local `uvicorn` dev, scripts run from the host) connect to. Inside
# docker-compose the backend container overrides it to http://elasticsearch:9200.
ES_HOST=http://localhost:9200
ES_INDEX=cars
ES_USER=
ES_PASSWORD=

# LLM — required for the AI Assistant (/assistant) and /recommend.
# Each teammate uses their own key from https://console.anthropic.com
# (the account needs API credit; Claude app subscriptions don't cover API calls).
ANTHROPIC_API_KEY=
# haiku = cheap, fine for the demo; claude-opus-4-8 = smarter buy-path analysis.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Local Ollama (RAG / LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
